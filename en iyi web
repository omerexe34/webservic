@app.route("/api/data", methods=["GET", "POST"])
def api_data():
    if not supabase:
        return jsonify({'status': 'error', 'message': 'Veritabanı bağlantısı kurulamadı. Sunucu ayarlarını kontrol edin.'})

    # Bakım modunu kontrol et
    try:
        maint_res = supabase.table('settings').select('*').eq('id', 'maintenance').execute()
        maintenance_mode = (maint_res.data[0].get("value") == 'true') if maint_res.data else False
    except:
        maintenance_mode = False

    if request.method == "GET":
        today = datetime.datetime.now().strftime("%Y-%m-%d")
        
        # --- XP DAĞITIM KONTROLÜ (Günü gelen etkinlikler için) ---
        try:
            events_res = supabase.table('events').select('*').execute()
            for ev_data in events_res.data:
                ev_id = str(ev_data.get('id'))
                ev_date = ev_data.get('datetime', '').split(' ')[0] 
                
                if ev_date <= today and not ev_data.get('xp_awarded'):
                    creator = ev_data.get('creator')
                    attendees = ev_data.get('attendees', [])
                    
                    if creator:
                        u_res = supabase.table('users').select('*').eq('username', creator).execute()
                        if u_res.data:
                            u_d = u_res.data[0]
                            new_xp = u_d.get('xp', 0) + 200
                            stats = u_d.get('stats', {"markers":0, "events":0, "market":0})
                            stats['events'] = stats.get('events', 0) + 1
                            supabase.table('users').update({"xp": new_xp, "stats": stats}).eq('username', creator).execute()
                    
                    for att in attendees:
                        if att != creator:
                            att_res = supabase.table('users').select('*').eq('username', att).execute()
                            if att_res.data:
                                att_d = att_res.data[0]
                                new_att_xp = att_d.get('xp', 0) + 100
                                supabase.table('users').update({"xp": new_att_xp}).eq('username', att).execute()
                    
                    supabase.table('events').update({"xp_awarded": True}).eq('id', ev_id).execute()
        except Exception as e:
            print("XP Dağıtım Hatası:", e)
        # -----------------------------------------------------------

        safe_users = []
        try:
            users_res = supabase.table('users').select('*').execute()
            for u in users_res.data:
                u.pop('password', None)
                safe_users.append(u)
        except Exception: pass
            
        banned_users = []
        try:
            banned_res = supabase.table('banned').select('*').execute()
            banned_users = [r['username'] for r in banned_res.data]
        except Exception: pass
        
        db_data = {
            'users': safe_users, 
            'banned': banned_users, 
            'maintenance': maintenance_mode
        }
        
        tables = ['markers', 'messages', 'reports', 'news', 'market', 'events']
        for table in tables:
            try:
                res = supabase.table(table).select('*').execute()
                db_data[table] = res.data
            except Exception:
                db_data[table] = []
            
        return jsonify(db_data)
        
    elif request.method == "POST":
        if request.content_length and request.content_length > MAX_PAYLOAD_SIZE:
            return jsonify({'status': 'error', 'message': 'Gönderilen veri çok büyük! Dosyalarınızın boyutunu küçültün.'})

        req = request.json
        action = req.get('action')
        data = req.get('data', {})
        # MongoDB'deki data.pop('_id', None) kısmı Supabase için gerekli değil, sildik.
        
        try:
            # Login & Register
            if action == 'login':
                if maintenance_mode and data.get('username') != 'Admin':
                    return jsonify({'status': 'error', 'message': 'Sistem şu an bakım modunda. Lütfen daha sonra tekrar deneyin.'})
                
                username = html.escape(data.get('username', '').strip())
                user_res = supabase.table('users').select('*').eq('username', username).execute()
                
                if user_res.data:
                    user_data = user_res.data[0]
                    banned_res = supabase.table('banned').select('*').eq('username', username).execute()
                    if banned_res.data:
                        return jsonify({'status': 'error', 'message': 'Hesabınız banlanmıştır!'})
                    
                    if check_password_hash(user_data.get('password', ''), data.get('password', '')):
                        session['username'] = user_data['username']
                        session['role'] = user_data.get('role', 'user')
                        user_data.pop('password', None)
                        return jsonify({'status': 'ok', 'user': user_data})
                return jsonify({'status': 'error', 'message': 'Hatalı kullanıcı adı veya şifre!'})

            elif action == 'register':
                if maintenance_mode:
                    return jsonify({'status': 'error', 'message': 'Sistem bakım modundayken kayıt olunamaz.'})
                    
                username = html.escape(data.get('username', '').strip())
                user_res = supabase.table('users').select('*').eq('username', username).execute()
                if user_res.data:
                    return jsonify({'status': 'error', 'message': 'Bu kullanıcı adı zaten alınmış!'})
                
                data['username'] = username
                data['name'] = html.escape(data.get('name', ''))
                data['bio'] = html.escape(data.get('bio', ''))
                data['city'] = html.escape(data.get('city', ''))
                data['password'] = generate_password_hash(data.get('password', ''))
                data['role'] = 'user'
                data['xp'] = 100 # Default XP
                data['stats'] = {"markers": 0, "events": 0, "market": 0}
                data['accepted_chat_rules'] = False 
                
                supabase.table('users').insert(data).execute()
                return jsonify({'status': 'ok'})

            elif action == 'logout':
                session.clear()
                return jsonify({'status': 'ok'})

            # --- OTURUM ŞART OLAN İŞLEMLER ---
            if 'username' not in session:
                return jsonify({'status': 'error', 'message': 'Giriş yapmalısınız!'})

            current_username = session['username']
            is_admin = session.get('role') == 'Admin'

            if maintenance_mode and not is_admin:
                session.clear()
                return jsonify({'status': 'error', 'message': 'Sistem bakıma alındı, oturum sonlandırıldı.'})

            # KULLANICI GÜNCELLEME
            if action == 'update_user':
                target_user = data.get('username')
                if target_user != current_username and not is_admin:
                    return jsonify({'status': 'error', 'message': 'Yetkisiz işlem!'})
                
                old_res = supabase.table('users').select('*').eq('username', target_user).execute()
                if old_res.data:
                    old_data = old_res.data[0]
                    new_pass = data.get('password')
                    data['password'] = generate_password_hash(new_pass) if (new_pass and new_pass.strip()) else old_data.get('password')
                    data['name'] = html.escape(data.get('name', ''))
                    data['bio'] = html.escape(data.get('bio', ''))
                    data['stats'] = data.get('stats', old_data.get('stats', {"markers":0, "events":0, "market":0}))
                    data['accepted_chat_rules'] = data.get('accepted_chat_rules', old_data.get('accepted_chat_rules', False))
                    
                    supabase.table('users').update(data).eq('username', target_user).execute()

            elif action == 'accept_chat_rules':
                supabase.table('users').update({"accepted_chat_rules": True}).eq('username', current_username).execute()

            elif action == 'update_user_role':
                if not is_admin: return jsonify({'status': 'error', 'message': 'Yetkisiz işlem!'})
                target = data.get('username')
                new_role = data.get('role')
                supabase.table('users').update({"role": new_role}).eq('username', target).execute()

            # HARİTA RAMPALARI VE İŞLEMLERİ
            elif action == 'add_marker':
                data['name'] = html.escape(data.get('name', ''))
                data['desc'] = html.escape(data.get('desc', ''))
                data['addedBy'] = current_username
                if 'likes' not in data: data['likes'] = []
                if 'fake_reports' not in data: data['fake_reports'] = []
                data['id'] = str(data['id'])
                
                supabase.table('markers').upsert(data).execute()
                
            elif action == 'delete_marker':
                if not is_admin: return jsonify({'status': 'error', 'message': 'Yetkisiz!'})
                supabase.table('markers').delete().eq('id', str(data.get('id'))).execute()
                
            elif action == 'like_marker':
                marker_id = str(data.get('id'))
                m_res = supabase.table('markers').select('*').eq('id', marker_id).execute()
                if m_res.data:
                    m_data = m_res.data[0]
                    likes = m_data.get('likes', [])
                    if current_username in likes:
                        likes.remove(current_username)
                    else:
                        likes.append(current_username)
                    supabase.table('markers').update({"likes": likes}).eq('id', marker_id).execute()

            elif action == 'report_marker_fake':
                marker_id = str(data.get('id'))
                m_res = supabase.table('markers').select('*').eq('id', marker_id).execute()
                if m_res.data:
                    m_data = m_res.data[0]
                    reports = m_data.get('fake_reports', [])
                    if current_username not in reports:
                        reports.append(current_username)
                        if len(reports) >= 3:
                            supabase.table('markers').delete().eq('id', marker_id).execute()
                        else:
                            supabase.table('markers').update({"fake_reports": reports}).eq('id', marker_id).execute()

            # CHAT MESAJLARI
            elif action == 'add_message':
                u_res = supabase.table('users').select('*').eq('username', current_username).execute()
                if u_res.data:
                    u_data = u_res.data[0]
                    if not u_data.get('accepted_chat_rules', False) and current_username != "Admin":
                        return jsonify({'status': 'error', 'message': 'Sohbet kurallarını kabul etmelisiniz!'})

                if data.get('type') == 'text':
                    data['text'] = html.escape(data.get('text', ''))
                data['user'] = current_username
                data['id'] = str(data['id'])
                supabase.table('messages').upsert(data).execute()
                
            elif action == 'delete_message':
                msg_id = str(data.get('id'))
                msg_res = supabase.table('messages').select('*').eq('id', msg_id).execute()
                if msg_res.data:
                    msg_data = msg_res.data[0]
                    if is_admin or msg_data.get('user') == current_username:
                        supabase.table('messages').delete().eq('id', msg_id).execute()

            # PAZAR YERİ
            elif action == 'add_market':
                today = datetime.datetime.now().strftime("%Y-%m-%d")
                
                user_ads_res = supabase.table('market').select('id').eq('owner', current_username).like('date', f'{today}%').execute()
                user_ads_today = len(user_ads_res.data)
                        
                if user_ads_today >= 2 and not is_admin:
                    return jsonify({'status': 'error', 'message': 'Günlük 2 adet ilan sınırını doldurdunuz!'})

                data['title'] = html.escape(data.get('title', ''))
                data['desc'] = html.escape(data.get('desc', ''))
                data['contact'] = html.escape(data.get('contact', ''))
                data['owner'] = current_username
                data['date'] = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
                data['id'] = str(data['id'])
                
                supabase.table('market').upsert(data).execute()

            elif action == 'delete_market':
                ad_id = str(data.get('id'))
                ad_res = supabase.table('market').select('*').eq('id', ad_id).execute()
                if ad_res.data:
                    ad = ad_res.data[0]
                    if ad.get('owner') == current_username or is_admin:
                        supabase.table('market').delete().eq('id', ad_id).execute()
                    else:
                        return jsonify({'status': 'error', 'message': 'Bu ilanı silemezsiniz!'})

            # SÜRÜŞ ETKİNLİKLERİ
            elif action == 'add_event':
                data['title'] = html.escape(data.get('title', ''))
                data['desc'] = html.escape(data.get('desc', ''))
                data['creator'] = current_username
                data['attendees'] = [current_username]
                data['xp_awarded'] = False
                data['id'] = str(data['id'])
                
                supabase.table('events').upsert(data).execute()

            elif action == 'join_event':
                ev_id = str(data.get('id'))
                event_res = supabase.table('events').select('*').eq('id', ev_id).execute()
                if event_res.data:
                    event = event_res.data[0]
                    attendees = event.get('attendees', [])
                    if current_username not in attendees:
                        attendees.append(current_username)
                        supabase.table('events').update({"attendees": attendees}).eq('id', ev_id).execute()
                        
            elif action == 'leave_event':
                ev_id = str(data.get('id'))
                event_res = supabase.table('events').select('*').eq('id', ev_id).execute()
                if event_res.data:
                    event = event_res.data[0]
                    attendees = event.get('attendees', [])
                    if current_username in attendees:
                        attendees.remove(current_username)
                        supabase.table('events').update({"attendees": attendees}).eq('id', ev_id).execute()

            elif action == 'delete_event':
                ev_id = str(data.get('id'))
                event_res = supabase.table('events').select('*').eq('id', ev_id).execute()
                if event_res.data:
                    event = event_res.data[0]
                    if event.get('creator') == current_username or is_admin:
                        supabase.table('events').delete().eq('id', ev_id).execute()

            # ŞİKAYET, BAN, HABER VE YÖNETİM
            elif action == 'add_report':
                report_id = str(data.get('user')) + "_" + current_username
                data['reportedBy'] = current_username
                data['reason'] = html.escape(data.get('reason', 'Neden belirtilmedi'))
                data['id'] = report_id
                supabase.table('reports').upsert(data).execute()

            elif action == 'add_ban':
                if not is_admin: return jsonify({'status': 'error', 'message': 'Yetkisiz!'})
                supabase.table('banned').upsert({"username": data.get('username')}).execute()

            elif action == 'add_news':
                if not is_admin: return jsonify({'status': 'error', 'message': 'Yetkisiz!'})
                data['title'] = html.escape(data.get('title', ''))
                data['content'] = html.escape(data.get('content', ''))
                data['id'] = str(data['id'])
                supabase.table('news').upsert(data).execute()

            elif action == 'delete_news':
                if not is_admin: return jsonify({'status': 'error', 'message': 'Yetkisiz!'})
                supabase.table('news').delete().eq('id', str(data['id'])).execute()
                
            elif action == 'toggle_maintenance':
                if not is_admin: return jsonify({'status': 'error', 'message': 'Yetkisiz!'})
                val = 'true' if data.get('status') else 'false'
                supabase.table('settings').upsert({"id": "maintenance", "value": val}).execute()

            return jsonify({'status': 'ok'})
            
        except Exception as e:
            print("HATA:", e)
            return jsonify({'status': 'error', 'message': f'İşlem sırasında bir hata oluştu: {e}'})

