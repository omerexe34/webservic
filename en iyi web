    <script>
        let currentUser = null;
        let map, userLat=39.0, userLng=35.0, userMarker=null;
        let tempLat, tempLng;
        let db = { users: [], markers: [], messages: [], market: [], events: [], news: [], reports: [], banned: [], maintenance: false };
        let markerLayers = [];
        let currentMessageCount = 0;
        let currentEventId = null;
        let currentMarketId = null;
        let mediaRecorder;
        let audioChunks = [];
        window.currentOwner = null; 
        window.isPopupOpen = false; 
        
        // İşaretleme Modları
        let isAddingMarkerMode = false; 
        let isAddingEventMode = false;

        const TITLES = [
            { max: 499, name: "Çaylak", color: "text-zinc-400" },
            { max: 1999, name: "Deneyimli", color: "text-blue-500" },
            { max: 4999, name: "Usta", color: "text-amber-500" },
            { max: 999999, name: "Efsane", color: "text-red-500 neon-glow" }
        ];

        async function sendAction(action, data) {
            const res = await fetch('/api/data', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action, data }) });
            const result = await res.json();
            if(result.status === 'error') { alert(result.message); throw new Error(result.message); }
            return result;
        }

        async function loadData(isInitial = false) {
            try {
                const res = await fetch('/api/data');
                const newData = await res.json();
                
                // Kasma önleme: Eğer mesaj veya pin sayısı değişmediyse DOM'u zorlama.
                let dataChanged = false;
                if(db.messages.length !== newData.messages.length || db.markers.length !== newData.markers.length || db.events.length !== newData.events.length) {
                    dataChanged = true;
                }
                
                db = newData;
                
                if (currentUser) {
                    const me = db.users.find(u => u.username === currentUser.username);
                    if (me) {
                        currentUser = me;
                        localStorage.setItem("fr_user", JSON.stringify(currentUser));
                        updateProfileUI();
                    }
                    if (db.banned.includes(currentUser.username) || (db.maintenance && currentUser.role !== 'Admin')) {
                        logout();
                    }
                }
                return dataChanged || isInitial;
            } catch(e) { console.error("Veri çekilemedi", e); return false; }
        }

        window.onload = async function() {
            // Beni Hatırla Kontrolü
            const savedUsername = localStorage.getItem("fr_remembered_username");
            if(savedUsername) {
                document.getElementById("login-username").value = savedUsername;
                document.getElementById("remember-me").checked = true;
            }

            await loadData(true);
            const saved = localStorage.getItem("fr_user");
            if (saved) currentUser = JSON.parse(saved);

            if (currentUser && !db.banned.includes(currentUser.username)) {
                if(db.maintenance && currentUser.role !== 'Admin') {
                    alert("Sistem bakımda.");
                    logout();
                } else {
                    loginSuccess();
                }
            }

            // KASMA SORUNU ÇÖZÜMÜ: 1 saniye olan intervali 5 saniyeye (5000ms) çektik.
            // Sadece değişiklik varsa haritayı ve dom'u zorla.
            setInterval(async () => {
                const changed = await loadData();
                if(currentUser && map) {
                    if (changed) syncMap(); // Sadece pin/event değiştiyse sil baştan kur
                    
                    if(db.messages.length > currentMessageCount) {
                        renderChat();
                        const lastMsg = db.messages[db.messages.length - 1];
                        if(lastMsg.user !== currentUser.username) {
                            try {
                                const audio = document.getElementById("notif-sound");
                                audio.currentTime = 0; 
                                audio.play().catch(e => console.log("Ses engellendi"));
                            } catch(e) {}
                        }
                        currentMessageCount = db.messages.length;
                    }
                    
                    renderMarket();
                    renderNews();
                    renderRank();
                }
            }, 5000); 
        };

        function showLoginTab() {
            document.getElementById("login-form").classList.remove("hidden");
            document.getElementById("register-form").classList.add("hidden");
            document.getElementById("login-tab-btn").classList.add("border-b-2","border-red-600","text-red-500");
            document.getElementById("register-tab-btn").classList.remove("border-b-2","border-red-600","text-red-500");
        }
        function showRegisterTab() {
            document.getElementById("login-form").classList.add("hidden");
            document.getElementById("register-form").classList.remove("hidden");
            document.getElementById("register-tab-btn").classList.add("border-b-2","border-red-600","text-red-500");
            document.getElementById("login-tab-btn").classList.remove("border-b-2","border-red-600","text-red-500");
        }

        async function handleLogin() {
            const u = document.getElementById("login-username").value, p = document.getElementById("login-password").value;
            const remember = document.getElementById("remember-me").checked;
            
            if(!u || !p) return;
            try {
                const res = await sendAction('login', {username:u, password:p});
                currentUser = res.user;
                localStorage.setItem("fr_user", JSON.stringify(currentUser));
                
                if (remember) localStorage.setItem("fr_remembered_username", u);
                else localStorage.removeItem("fr_remembered_username");
                
                loginSuccess();
            } catch(e) {}
        }

        async function handleRegister() {
            const u = document.getElementById("reg-username").value, p = document.getElementById("reg-password").value;
            const n = document.getElementById("reg-name").value, c = document.getElementById("reg-city").value;
            if(!u||!p||!n||!c) return alert("Boş alan bırakmayın!");
            try {
                const avatarUrl = `https://loremflickr.com/128/128/mountainbike,freeride,downhill?random=${u}`;
                await sendAction('register', {username:u, password:p, name:n, city:c, xp:100, avatar:avatarUrl});
                alert("Kayıt başarılı! Sahaya inebilirsin.");
                showLoginTab();
                
                // Kayıt olanı oto hatırla
                document.getElementById("login-username").value = u;
                document.getElementById("login-password").value = p;
                document.getElementById("remember-me").checked = true;
            } catch(e) {}
        }

        async function logout() {
            await sendAction('logout', {});
            localStorage.removeItem("fr_user");
            location.reload();
        }

        function loginSuccess() {
            document.getElementById("login-screen").classList.add("hidden");
            document.getElementById("main-app").classList.remove("hidden");
            updateProfileUI();
            initMap();
            switchTab(0);
            renderChat();
            currentMessageCount = db.messages.length;
        }

        function getTitle(xp) {
            for(let t of TITLES) { if(xp <= t.max) return t; }
            return TITLES[TITLES.length-1];
        }

        function updateProfileUI() {
            if(!currentUser) return;
            document.getElementById("top-username").textContent = currentUser.username;
            document.getElementById("top-avatar").src = currentUser.avatar;
            
            const title = getTitle(currentUser.xp);
            document.getElementById("top-title").textContent = title.name;
            document.getElementById("top-title").className = `text-[10px] font-bold uppercase tracking-wider ${title.color}`;
            
            document.getElementById("profile-name").textContent = currentUser.name || currentUser.username;
            document.getElementById("profile-bio").textContent = currentUser.bio || "Bio yok";
            document.getElementById("profile-xp").textContent = currentUser.xp;
            document.getElementById("profile-avatar").src = currentUser.avatar;
            document.getElementById("profile-title").textContent = title.name;
            document.getElementById("profile-title").className = `text-lg font-bold uppercase mt-1 ${title.color}`;
            
            const s = currentUser.stats || {markers:0, events:0, market:0};
            let badges = "";
            if(s.markers >= 5) badges += `<span class="bg-blue-950/50 text-blue-400 border border-blue-900/50 px-3 py-1 rounded-lg text-[10px] font-bold shadow-sm uppercase tracking-wider">📍 Yer Uzmanı</span>`;
            if(s.events >= 3) badges += `<span class="bg-purple-950/50 text-purple-400 border border-purple-900/50 px-3 py-1 rounded-lg text-[10px] font-bold shadow-sm uppercase tracking-wider">👑 Sürüş Kralı</span>`;
            if(s.market >= 2) badges += `<span class="bg-green-950/50 text-green-400 border border-green-900/50 px-3 py-1 rounded-lg text-[10px] font-bold shadow-sm uppercase tracking-wider">🤝 Aktif Satıcı</span>`;
            if(badges==="") badges = "<span class='text-zinc-500 text-xs italic'>Henüz rozet yok.</span>";
            
            document.getElementById("profile-badges").innerHTML = badges;
            document.getElementById("admin-btn").classList.toggle("hidden", currentUser.role !== 'Admin');
        }

        function showOtherProfile(targetUsername) {
            if(targetUsername === currentUser.username) {
                switchTab(5); 
                document.getElementById('market-detail-modal').classList.add('hidden');
                document.getElementById('event-sheet').classList.add('hidden');
                return;
            }

            const u = db.users.find(x => x.username === targetUsername);
            if(!u) return alert("Kullanıcı bulunamadı!");

            document.getElementById("op-avatar").src = u.avatar || `https://loremflickr.com/128/128/mountainbike?random=${u.username}`;
            document.getElementById("op-username").textContent = u.name || u.username;
            document.getElementById("op-bio").textContent = u.bio || "Kullanıcı biyo girmemiş.";
            document.getElementById("op-xp").textContent = u.xp;
            
            const title = getTitle(u.xp);
            document.getElementById("op-title").textContent = title.name;
            document.getElementById("op-title").className = `text-md font-bold truncate uppercase ${title.color}`;
            
            const s = u.stats || {markers:0, events:0, market:0};
            let badges = "";
            if(s.markers >= 5) badges += `<span class="bg-blue-950/50 text-blue-400 border border-blue-900/50 px-3 py-1 rounded-lg text-[10px] font-bold shadow-sm uppercase tracking-wider">📍 Yer Uzmanı</span>`;
            if(s.events >= 3) badges += `<span class="bg-purple-950/50 text-purple-400 border border-purple-900/50 px-3 py-1 rounded-lg text-[10px] font-bold shadow-sm uppercase tracking-wider">👑 Sürüş Kralı</span>`;
            if(s.market >= 2) badges += `<span class="bg-green-950/50 text-green-400 border border-green-900/50 px-3 py-1 rounded-lg text-[10px] font-bold shadow-sm uppercase tracking-wider">🤝 Aktif Satıcı</span>`;
            if(badges==="") badges = "<span class='text-zinc-500 text-xs'>Kullanıcının henüz rozeti yok.</span>";
            
            document.getElementById("op-badges").innerHTML = badges;

            let actionsHtml = `<button onclick="reportUser('${u.username}')" class="bg-darker hover:bg-red-950 text-red-500 py-3 px-4 rounded-xl text-sm font-bold w-full transition border border-red-900/50">🚨 Kullanıcıyı Şikayet Et</button>`;
            
            if(currentUser.role === 'Admin') {
                actionsHtml += `<div class="flex gap-2 mt-3 mb-3">
                    <input id="admin-xp-amount" type="number" placeholder="XP Miktarı" class="w-1/2 bg-zinc-800 text-white rounded-xl px-3 py-2 text-sm border border-zinc-700">
                    <button onclick="giveXP('${u.username}')" class="w-1/2 bg-green-700 hover:bg-green-600 text-white py-2 rounded-xl text-xs font-bold shadow-md transition uppercase">XP VER</button>
                </div>`;
                
                actionsHtml += `<div class="flex gap-2 mt-3">
                    <button onclick="banUser('${u.username}')" class="bg-red-700 hover:bg-red-600 text-white py-3 px-4 rounded-xl text-xs font-bold flex-1 shadow-md transition uppercase">Banla</button>`;
                
                if (u.role === 'Admin') {
                    actionsHtml += `<button onclick="removeAdmin('${u.username}')" class="bg-zinc-700 hover:bg-zinc-600 text-white py-3 px-4 rounded-xl text-xs font-bold flex-1 shadow-md transition uppercase">Yetki Al</button>`;
                } else {
                    actionsHtml += `<button onclick="makeAdmin('${u.username}')" class="bg-amber-700 hover:bg-amber-600 text-white py-3 px-4 rounded-xl text-xs font-bold flex-1 shadow-md transition uppercase">Admin Yap</button>`;
                }
                actionsHtml += `</div>`;
            }
            document.getElementById("op-actions").innerHTML = actionsHtml;
            document.getElementById("other-profile-modal").classList.remove("hidden");
        }

        async function reportUser(username) {
            const reason = prompt(`Lütfen ${username} adlı kullanıcıyı neden şikayet ettiğini kısaca yaz:`);
            if(reason !== null && reason.trim() !== "") {
                await sendAction('add_report', {user: username, reason: reason});
                alert("Şikayetiniz yöneticilere iletildi. Teşekkürler!");
                document.getElementById("other-profile-modal").classList.add("hidden");
            }
        }

        async function makeAdmin(username) {
            if(confirm(username + " adlı kullanıcıya ADMIN yetkisi vermek istediğine emin misin?")) {
                await sendAction('update_user_role', {username: username, role: 'Admin'});
                alert(username + " artık bir Admin!");
                document.getElementById("other-profile-modal").classList.add("hidden");
                loadData();
            }
        }

        async function removeAdmin(username) {
            if(confirm(username + " adlı kullanıcının ADMIN yetkisini almak istediğine emin misin?")) {
                await sendAction('update_user_role', {username: username, role: 'user'});
                alert(username + " artık normal bir kullanıcı!");
                document.getElementById("other-profile-modal").classList.add("hidden");
                loadData();
            }
        }

        // ================= MAP & EVENTS & YAKIN ROTALAR =================
        function initMap() {
            if(map) return;
            map = L.map('map', {zoomControl: false}).setView([39.0, 35.0], 6);
            
            // Daha dark bir tile layer (Karanlık tema hissi için)
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://carto.com/">CARTO</a>'
            }).addTo(map);
            
            syncMap(true);
            
            map.on('popupopen', () => window.isPopupOpen = true);
            map.on('popupclose', () => window.isPopupOpen = false);
            
            map.on('click', function(e) {
                if(!isAddingMarkerMode && !isAddingEventMode) return;
                
                tempLat = e.latlng.lat; 
                tempLng = e.latlng.lng;
                
                if (isAddingMarkerMode) {
                    toggleAddMarkerMode(); 
                    openAddMarkerModal();
                } else if (isAddingEventMode) {
                    toggleAddEventMode();
                    openAddEventModal();
                }
            });
            autoZoomToUserLocation();
        }
        
        function toggleAddMarkerMode() {
            if(isAddingEventMode) toggleAddEventMode(); // diğerini kapat
            isAddingMarkerMode = !isAddingMarkerMode;
            
            const btn = document.getElementById("btn-add-marker-mode");
            const mapContainer = document.getElementById("map");
            const toastId = "map-toast-marker";
            
            if(isAddingMarkerMode) {
                btn.classList.remove("bg-red-700", "border-red-900");
                btn.classList.add("bg-green-600", "border-green-800", "animate-pulse");
                btn.innerHTML = "❌ Haritadan Yer Seç (İptal)";
                mapContainer.classList.add("map-add-mode");
                
                const toast = document.createElement("div");
                toast.id = toastId;
                toast.className = "absolute top-20 left-1/2 -translate-x-1/2 bg-green-600 text-white px-4 py-2 rounded-xl font-bold text-sm shadow-[0_0_15px_rgba(22,163,74,0.6)] z-[9999] pointer-events-none text-center border border-green-400";
                toast.innerHTML = "📍 Rampa eklenecek yere<br>haritadan dokunun!";
                document.getElementById("screen-map").appendChild(toast);
            } else {
                btn.classList.add("bg-red-700", "border-red-900");
                btn.classList.remove("bg-green-600", "border-green-800", "animate-pulse");
                btn.innerHTML = "📍 Rampa İşaretle";
                mapContainer.classList.remove("map-add-mode");
                const toast = document.getElementById(toastId);
                if(toast) toast.remove();
            }
        }

        // YENİ: Buluşma ekleme modu
        function toggleAddEventMode() {
            if(isAddingMarkerMode) toggleAddMarkerMode(); // diğerini kapat
            isAddingEventMode = !isAddingEventMode;
            
            const btn = document.getElementById("btn-add-event-mode");
            const mapContainer = document.getElementById("map");
            const toastId = "map-toast-event";
            
            if(isAddingEventMode) {
                btn.classList.remove("bg-blue-700", "border-blue-900");
                btn.classList.add("bg-green-600", "border-green-800", "animate-pulse");
                btn.innerHTML = "❌ Haritadan Yer Seç (İptal)";
                mapContainer.classList.add("map-add-mode");
                
                const toast = document.createElement("div");
                toast.id = toastId;
                toast.className = "absolute top-20 left-1/2 -translate-x-1/2 bg-blue-600 text-white px-4 py-2 rounded-xl font-bold text-sm shadow-[0_0_15px_rgba(37,99,235,0.6)] z-[9999] pointer-events-none text-center border border-blue-400";
                toast.innerHTML = "📅 Buluşma yerine<br>haritadan dokunun!";
                document.getElementById("screen-map").appendChild(toast);
            } else {
                btn.classList.add("bg-blue-700", "border-blue-900");
                btn.classList.remove("bg-green-600", "border-green-800", "animate-pulse");
                btn.innerHTML = "📅 Buluşma İşaretle";
                mapContainer.classList.remove("map-add-mode");
                const toast = document.getElementById(toastId);
                if(toast) toast.remove();
            }
        }
        
        function openAddMarkerModal() { 
            document.getElementById("new-marker-name").value = "";
            document.getElementById("new-marker-desc").value = "";
            document.getElementById("new-marker-photo").value = "";
            document.getElementById("new-marker-preview").classList.add("hidden");
            document.getElementById("add-marker-modal").classList.remove("hidden"); 
        }

        function openAddEventModal() { 
            document.getElementById("ev-title").value = "";
            document.getElementById("ev-date").value = "";
            document.getElementById("ev-time").value = "";
            document.getElementById("ev-max").value = "";
            document.getElementById("ev-desc").value = "";
            document.getElementById("add-event-modal").classList.remove("hidden"); 
        }
        
        function previewMarkerPhoto(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    const prev = document.getElementById("new-marker-preview");
                    prev.src = e.target.result;
                    prev.classList.remove("hidden");
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function syncMap(force = false) {
            if (window.isPopupOpen && !force) return;

            markerLayers.forEach(l => map.removeLayer(l));
            markerLayers = [];
            
            db.markers.forEach(m => {
