        function switchTab(n) {
            const tabs = ["screen-map", "screen-chat", "screen-market", "screen-rank", "screen-news", "screen-profile"];
            tabs.forEach((id,i) => document.getElementById(id).classList.toggle("hidden", i !== n));
            for(let i=0; i<6; i++) {
                if(i===4 && n!==4 && n!==3) continue; // Chat DM/Group logic
                const b = document.getElementById(`tab-btn-${i}`);
                if(!b) continue;
                if(i===n) { b.classList.add("text-red-500"); b.classList.remove("text-zinc-500"); }
                else { b.classList.remove("text-red-500"); b.classList.add("text-zinc-500"); }
            }
            if(n===0 && map) setTimeout(()=>map.invalidateSize(), 100);
            
            if(n === 1 && currentUser && !currentUser.accepted_chat_rules && currentUser.role !== 'Admin') {
                document.getElementById("chat-rules-modal").classList.remove("hidden");
            }

            if(n===2) renderMarket();
            if(n===3) renderRank();
            if(n===4) renderNews();
        }

        function renderRank() {
            const c = document.getElementById("leaderboard"); c.innerHTML = "";
            [...db.users].sort((a,b)=>b.xp-a.xp).slice(0,20).forEach((u,i) => {
                const t = getTitle(u.xp);
                c.innerHTML += `<div class="flex items-center justify-between bg-darker px-4 py-3 rounded-xl border border-zinc-800 cursor-pointer hover:border-red-900/50 transition shadow-sm mb-2" onclick="showOtherProfile('${u.username}')">
                    <div class="flex items-center gap-3">
                        <span class="text-xl font-black w-6 text-center">${i===0?'🥇':i===1?'🥈':i===2?'🥉':i+1}</span>
                        <img src="${u.avatar || `https://loremflickr.com/128/128/mountainbike?random=${u.username}`}" class="w-10 h-10 rounded-lg object-cover border border-zinc-700">
                        <div><div class="font-bold text-sm break-all text-zinc-200">${u.username} ${u.role==='Admin'?'👑':''}</div><div class="text-[10px] uppercase font-bold tracking-wider ${t.color}">${t.name}</div></div>
                    </div>
                    <div class="text-right"><div class="text-2xl text-red-500 teko-font tracking-wider">${u.xp}</div><div class="text-[9px] text-zinc-600 font-bold uppercase">XP</div></div>
                </div>`;
            });
        }

        function renderNews() {
            const c = document.getElementById("news-list"); c.innerHTML = "";
            if(db.news.length === 0) c.innerHTML = "<div class='text-center text-zinc-600 py-10 italic'>Haber yok.</div>";
            db.news.forEach(n => {
                c.innerHTML += `<div class="bg-darker p-5 rounded-xl border border-zinc-800 shadow-md mb-4">
                    <h3 class="font-bold text-xl text-red-500 mb-2 break-all teko-font tracking-wide">${n.title}</h3>
                    <p class="text-sm text-zinc-300 whitespace-pre-wrap break-words leading-relaxed">${n.content}</p>
                    ${currentUser.role==='Admin'?`<button onclick="delNews('${n.id}')" class="text-xs text-red-500 mt-4 font-bold bg-red-950/30 border border-red-900/30 px-3 py-1.5 rounded-lg uppercase tracking-wider">🗑️ Haberi Sil</button>`:''}
                </div>`;
            });
        }

        // ================= ADMIN PANELİ =================
        function showAdminPanel() {
            document.getElementById("admin-maintenance").checked = db.maintenance;
            
            const rC = document.getElementById("admin-reports"); rC.innerHTML = "";
            db.reports.forEach(r => {
                rC.innerHTML += `<div class="bg-zinc-900 p-4 rounded-xl border border-zinc-800 text-sm mb-3 shadow-sm">
                    <div class="mb-1 text-zinc-300">Hedef: <b class="text-red-500">${r.user}</b></div>
                    <div class="text-xs text-zinc-500 mb-3 bg-darker p-2 rounded border border-zinc-800">Neden: ${r.reason || 'Belirtilmedi'}</div>
                    <button onclick="banUser('${r.user}')" class="bg-red-700 hover:bg-red-600 text-white px-3 py-2 rounded-lg text-xs font-bold w-full transition tracking-widest uppercase">Kalıcı Banla</button>
                </div>`;
            });
            document.getElementById("admin-panel").classList.remove("hidden");
        }

        async function toggleMaintenance() {
            const st = document.getElementById("admin-maintenance").checked;
            await sendAction('toggle_maintenance', {status: st});
            loadData(true);
        }

        function openNewsAdminModal() { document.getElementById("news-admin-modal").classList.remove("hidden"); }
        async function saveNews() {
            const t = document.getElementById("news-title").value, c = document.getElementById("news-content").value;
            if(!t||!c) return;
            await sendAction('add_news', {id:Date.now(), title:t, content:c});
            document.getElementById("news-admin-modal").classList.add("hidden");
            loadData(true);
        }
        async function delNews(id) { await sendAction('delete_news', {id}); loadData(true); }
        async function banUser(u) {
            if(confirm(u + " banlanacak. Emin misin?")) {
                await sendAction('add_ban', {username: u});
                loadData(true);
            }
        }
        
        function showProfile() { switchTab(5); }
    </script>
</body>
