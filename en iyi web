                        <button onclick="openNewsAdminModal()" class="w-full bg-blue-700 py-4 rounded-xl font-bold text-white hover:bg-blue-600 transition tracking-widest teko-font text-xl shadow-lg">+ HABER / DUYURU EKLE</button>
