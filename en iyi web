        function toggleVoiceRecord() {
            if(!currentUser.accepted_chat_rules && currentUser.role !== "Admin") {
                document.getElementById("chat-rules-modal").classList.remove("hidden");
                return;
            }

            const btn = document.getElementById("voice-btn");
            if (!mediaRecorder || mediaRecorder.state === "inactive") {
                navigator.mediaDevices.getUserMedia({audio:true}).then(stream => {
                    mediaRecorder = new MediaRecorder(stream);
                    audioChunks = [];
                    mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
                    mediaRecorder.onstop = () => {
                        const blob = new Blob(audioChunks, {type:'audio/webm'});
                        const reader = new FileReader();
                        reader.readAsDataURL(blob);
                        reader.onloadend = async () => {
                            const tempId = Date.now().toString();
                            db.messages.push({id: tempId, audio: reader.result, type: "voice", user: currentUser.username});
                            renderChat();
                            currentMessageCount = db.messages.length;
                            
                            await sendAction('add_message', {id: tempId, audio: reader.result, type:"voice"});
                            loadData(true);
                        };
                    };
                    mediaRecorder.start();
                    btn.classList.add("bg-red-700", "animate-pulse", "border-red-500");
                    btn.classList.remove("bg-zinc-800", "border-zinc-700");
                }).catch(err => alert("Mikrofon izni alınamadı!"));
            } else {
                mediaRecorder.stop();
                btn.classList.remove("bg-red-700", "animate-pulse", "border-red-500");
                btn.classList.add("bg-zinc-800", "border-zinc-700");
            }
        }

