        <div id="news-admin-modal" class="hidden fixed inset-0 bg-black/95 flex items-center justify-center z-[9999] px-4 backdrop-blur-sm">
            <div class="bg-zinc-900 w-full max-w-md rounded-2xl p-6 border border-zinc-700 shadow-2xl">
                <input id="news-title" type="text" placeholder="Haber Başlığı" class="w-full bg-zinc-950 p-4 rounded-xl mb-3 outline-none text-white border border-zinc-800 focus:border-amber-600 transition">
                <textarea id="news-content" placeholder="İçerik..." class="w-full bg-zinc-950 p-4 rounded-xl h-24 mb-6 outline-none text-white border border-zinc-800 custom-scrollbar focus:border-amber-600 transition"></textarea>
                <div class="flex gap-3">
                    <button onclick="document.getElementById('news-admin-modal').classList.add('hidden')" class="flex-1 bg-zinc-800 py-4 rounded-xl text-white font-bold hover:bg-zinc-700 transition">İptal</button>
                    <button onclick="saveNews()" class="flex-1 bg-amber-700 py-4 rounded-xl font-bold text-white hover:bg-amber-600 transition tracking-widest teko-font text-xl">YAYINLA</button>
